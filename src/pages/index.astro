  <!-- Email obfuscation script -->
  <script>
    document.addEventListener('DOMContentLoaded', function() {
      // Smooth scrolling for navigation links
      document.querySelectorAll('.scroll-link').forEach(link => {
        link.addEventListener('click', function(e) {
          e.preventDefault();
          const targetId = this.getAttribute('href');
          const targetSection = document.querySelector(targetId);
          if (targetSection) {
            targetSection.scrollIntoView({
              behavior: 'smooth',
              block: 'start'
            });
          }
        });
      });

      // Function to check current section and update navigation
      function updateNavigation() {
        const sections = document.querySelectorAll('section[id]');
        const navLinks = document.querySelectorAll('.scroll-link');
        
        let current = '';
        sections.forEach(section => {
          const sectionTop = section.offsetTop - 100;
          const sectionHeight = section.offsetHeight;
          if (window.scrollY >= sectionTop && window.scrollY < sectionTop + sectionHeight) {
            current = section.getAttribute('id');
          }
        });

        // Update navigation links
        navLinks.forEach(link => {
          link.classList.remove('text-gray-900');
          link.classList.add('text-gray-600');
          if (link.getAttribute('href') === `#${current}`) {
            link.classList.remove('text-gray-600');
            link.classList.add('text-gray-900');
          }
        });
      }

      // Function to show scroll indicator on initial load
      function showScrollIndicator() {
        const scrollIndicator = document.getElementById('scroll-indicator');
        const aboutSection = document.getElementById('about');
        
        // Only show if we're at the top of the page (in about section)
        if (window.scrollY < 50 && scrollIndicator) {
          scrollIndicator.style.opacity = '1';
        }
      }

      // Hide scroll indicator on any scroll
      function hideScrollIndicator() {
        const scrollIndicator = document.getElementById('scroll-indicator');
        if (scrollIndicator) {
          scrollIndicator.style.opacity = '0';
        }
      }

      // Update navigation on scroll and hide indicator immediately
      window.addEventListener('scroll', function() {
        updateNavigation();
        hideScrollIndicator();
      });
      
      // Show indicator on initial load if at top of page
      setTimeout(showScrollIndicator, 100);

      // Archive toggle
      const archiveToggle = document.querySelector('.archive-toggle');
      const archiveContent = document.querySelector('.archive-content');
      const archiveArrow = document.querySelector('.archive-arrow');
      if (archiveToggle && archiveContent && archiveArrow) {
        archiveToggle.addEventListener('click', function(e) {
          e.preventDefault();
          const isHidden = archiveContent.classList.contains('hidden');
          if (isHidden) {
            archiveContent.classList.remove('hidden');
            archiveArrow.style.transform = 'rotate(180deg)';
          } else {
            archiveContent.classList.add('hidden');
            archiveArrow.style.transform = 'rotate(0deg)';
          }
          requestAnimationFrame(alignYearColumns);
        });
      }

      // Align each year label vertically with the center of its FIRST video,
      // and constrain the year-column so sticky unsticks at the LAST video's center.
      function alignYearColumns() {
        const isLg = window.matchMedia('(min-width: 1024px)').matches;
        document.querySelectorAll('.year-group').forEach(group => {
          const yearColumn = group.querySelector('.year-column');
          const yearSticky = yearColumn?.firstElementChild;
          if (!yearColumn) return;
          if (!isLg) {
            yearColumn.style.height = '';
            if (yearSticky) yearSticky.style.marginTop = '';
            return;
          }
          const images = group.querySelectorAll('.aspect-video');
          if (images.length === 0) return;
          const groupTop = group.getBoundingClientRect().top;

          const firstImage = images[0];
          const firstRect = firstImage.getBoundingClientRect();
          const firstCenter = (firstRect.top - groupTop) + firstRect.height / 2;
          if (yearSticky) {
            const yearTextHeight = yearSticky.offsetHeight || 30;
            yearSticky.style.marginTop = Math.max(0, firstCenter - yearTextHeight / 2) + 'px';
          }

          const lastImage = images[images.length - 1];
          const lastRect = lastImage.getBoundingClientRect();
          const stopPoint = (lastRect.top - groupTop) + lastRect.height / 2;
          yearColumn.style.height = stopPoint + 'px';
        });
      }
      alignYearColumns();
      window.addEventListener('load', alignYearColumns);
      let _yearResizeTimer;
      window.addEventListener('resize', () => {
        clearTimeout(_yearResizeTimer);
        _yearResizeTimer = setTimeout(alignYearColumns, 100);
      });

      // Contact form toggle
      const contactToggle = document.querySelector('.contact-toggle');
      const contactFormContent = document.querySelector('.contact-form-content');
      const contactArrow = document.querySelector('.contact-arrow');
      const contactToggleLabel = contactToggle?.querySelector('span');
      if (contactToggle && contactFormContent && contactArrow) {
        contactToggle.addEventListener('click', () => {
          const isHidden = contactFormContent.classList.contains('hidden');
          if (isHidden) {
            contactFormContent.classList.remove('hidden');
            contactArrow.style.transform = 'rotate(180deg)';
            if (contactToggleLabel) contactToggleLabel.textContent = 'Close form';
          } else {
            contactFormContent.classList.add('hidden');
            contactArrow.style.transform = 'rotate(0deg)';
            if (contactToggleLabel) contactToggleLabel.textContent = 'Open form';
          }
        });
      }

      // Contact form (AJAX submit, no redirect)
      const contactForm = document.getElementById('contact-form');
      const contactStatus = document.getElementById('contact-status');
      if (contactForm && contactStatus) {
        contactForm.addEventListener('submit', async (e) => {
          e.preventDefault();
          const submitBtn = contactForm.querySelector('button[type="submit"]');
          submitBtn.disabled = true;
          contactStatus.textContent = 'Sending…';
          contactStatus.className = 'text-sm text-center min-h-[1.25rem] text-gray-500';
          try {
            const response = await fetch(contactForm.action, {
              method: 'POST',
              body: new FormData(contactForm),
              headers: { Accept: 'application/json' }
            });
            if (response.ok) {
              contactStatus.textContent = 'Thanks — your message is on its way.';
              contactStatus.className = 'text-sm text-center min-h-[1.25rem] text-gray-700';
              contactForm.reset();
            } else {
              const data = await response.json().catch(() => ({}));
              throw new Error(data?.errors?.[0]?.message || 'Submission failed');
            }
          } catch (err) {
            contactStatus.textContent = 'Something went wrong. Please try again later.';
            contactStatus.className = 'text-sm text-center min-h-[1.25rem] text-red-500';
          } finally {
            submitBtn.disabled = false;
          }
        });
      }
    });
  </script>

